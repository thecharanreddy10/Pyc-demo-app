@page
@model PayrollApp.Pages.Employees.EditModel
@{
    ViewData["Title"] = "Edit Employee";
}

<h1>Edit Employee</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <input type="hidden" asp-for="Employee.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="Employee.EmployeeId" class="form-label"></label>
                <input asp-for="Employee.EmployeeId" class="form-control" />
                <span asp-validation-for="Employee.EmployeeId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.Name" class="form-label"></label>
                <input asp-for="Employee.Name" class="form-control" />
                <span asp-validation-for="Employee.Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.Email" class="form-label"></label>
                <input asp-for="Employee.Email" class="form-control" type="email" />
                <span asp-validation-for="Employee.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.Department" class="form-label"></label>
                <input asp-for="Employee.Department" class="form-control" />
                <span asp-validation-for="Employee.Department" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.EmploymentType" class="form-label"></label>
                <select asp-for="Employee.EmploymentType" class="form-select" id="employmentTypeSelect">
                    <option value="0">Salaried</option>
                    <option value="1">Hourly</option>
                </select>
                <span asp-validation-for="Employee.EmploymentType" class="text-danger"></span>
            </div>

            <div class="mb-3" id="salaryField">
                <label asp-for="Employee.AnnualSalary" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Employee.AnnualSalary" class="form-control" type="number" step="0.01" />
                </div>
                <span asp-validation-for="Employee.AnnualSalary" class="text-danger"></span>
            </div>

            <div class="mb-3" id="hourlyRateField">
                <label asp-for="Employee.HourlyRate" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Employee.HourlyRate" class="form-control" type="number" step="0.01" />
                    <span class="input-group-text">/hour</span>
                </div>
                <span asp-validation-for="Employee.HourlyRate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.HireDate" class="form-label"></label>
                <input asp-for="Employee.HireDate" class="form-control" type="date" />
                <span asp-validation-for="Employee.HireDate" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-page="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const employmentTypeSelect = document.getElementById('employmentTypeSelect');
            const salaryField = document.getElementById('salaryField');
            const hourlyRateField = document.getElementById('hourlyRateField');

            function updateFields() {
                if (employmentTypeSelect.value === '0') { // Salaried
                    salaryField.style.display = 'block';
                    hourlyRateField.style.display = 'none';
                } else if (employmentTypeSelect.value === '1') { // Hourly
                    salaryField.style.display = 'none';
                    hourlyRateField.style.display = 'block';
                }
            }

            employmentTypeSelect.addEventListener('change', updateFields);
            updateFields(); // Initial call
        });
    </script>
}
