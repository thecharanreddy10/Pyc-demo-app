@page
@model PayrollApp.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Employees</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Employee
    </a>
</div>

@if (Model.Employees.Count == 0)
{
    <div class="alert alert-info">
        No employees found. Click "Add New Employee" to create your first employee record.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Employee ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Department</th>
                    <th>Type</th>
                    <th>Salary/Rate</th>
                    <th>Hire Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employee in Model.Employees)
                {
                    <tr>
                        <td>@employee.EmployeeId</td>
                        <td>@employee.Name</td>
                        <td>@employee.Email</td>
                        <td>@employee.Department</td>
                        <td>
                            <span class="badge bg-@(employee.EmploymentType == PayrollApp.Models.EmploymentType.Salaried ? "info" : "success")">
                                @employee.EmploymentType
                            </span>
                        </td>
                        <td>
                            @if (employee.EmploymentType == PayrollApp.Models.EmploymentType.Salaried)
                            {
                                <text>$@employee.AnnualSalary?.ToString("N0")/year</text>
                            }
                            else
                            {
                                <text>$@employee.HourlyRate?.ToString("N2")/hour</text>
                            }
                        </td>
                        <td>@employee.HireDate.ToString("MM/dd/yyyy")</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-page="Details" asp-route-id="@employee.Id" class="btn btn-sm btn-info">Details</a>
                                <a asp-page="Edit" asp-route-id="@employee.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-page="Delete" asp-route-id="@employee.Id" class="btn btn-sm btn-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <p class="text-muted">
            Total Employees: <strong>@Model.Employees.Count</strong>
        </p>
    </div>
}
