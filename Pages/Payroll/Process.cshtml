@page
@model PayrollApp.Pages.Payroll.ProcessModel
@{
    ViewData["Title"] = "Process Payroll";
}

<h1>Process Payroll</h1>
<hr />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Generate Payroll</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="SelectedEmployeeId" class="form-label">Select Employee</label>
                        <select asp-for="SelectedEmployeeId" class="form-select" id="employeeSelect">
                            <option value="">-- Select an Employee --</option>
                            @foreach (var employee in Model.Employees)
                            {
                                <option value="@employee.Id" 
                                        data-type="@employee.EmploymentType"
                                        data-salary="@employee.AnnualSalary"
                                        data-hourly="@employee.HourlyRate">
                                    @employee.EmployeeId - @employee.Name (@employee.EmploymentType)
                                </option>
                            }
                        </select>
                        <span asp-validation-for="SelectedEmployeeId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PayPeriodStart" class="form-label">Pay Period Start</label>
                        <input asp-for="PayPeriodStart" class="form-control" type="date" />
                        <span asp-validation-for="PayPeriodStart" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PayPeriodEnd" class="form-label">Pay Period End</label>
                        <input asp-for="PayPeriodEnd" class="form-control" type="date" />
                        <span asp-validation-for="PayPeriodEnd" class="text-danger"></span>
                    </div>

                    <div class="mb-3" id="hoursWorkedField" style="display:none;">
                        <label asp-for="HoursWorked" class="form-label">Hours Worked</label>
                        <input asp-for="HoursWorked" class="form-control" type="number" step="0.5" placeholder="160" />
                        <span asp-validation-for="HoursWorked" class="text-danger"></span>
                        <small class="form-text text-muted">Default is 160 hours (4 weeks × 40 hours)</small>
                    </div>

                    <div class="alert alert-info mt-3">
                        <strong>Deduction Rates:</strong>
                        <ul class="mb-0">
                            <li>Tax: 15%</li>
                            <li>Social Security: 6.2%</li>
                            <li>Health Insurance: $200 (fixed)</li>
                        </ul>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-calculator"></i> Calculate & Process Payroll
                        </button>
                        <a asp-page="/Payroll/History" class="btn btn-secondary">View Payment History</a>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.ProcessedPayroll != null)
        {
            <div class="card mt-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Payroll Summary</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Employee:</dt>
                        <dd class="col-sm-8">@Model.ProcessedPayroll.Employee?.Name</dd>

                        <dt class="col-sm-4">Pay Period:</dt>
                        <dd class="col-sm-8">
                            @Model.ProcessedPayroll.PayPeriodStart.ToString("MM/dd/yyyy") - 
                            @Model.ProcessedPayroll.PayPeriodEnd.ToString("MM/dd/yyyy")
                        </dd>

                        @if (Model.ProcessedPayroll.HoursWorked.HasValue)
                        {
                            <dt class="col-sm-4">Hours Worked:</dt>
                            <dd class="col-sm-8">@Model.ProcessedPayroll.HoursWorked hours</dd>
                        }

                        <dt class="col-sm-4">Gross Pay:</dt>
                        <dd class="col-sm-8"><strong>$@Model.ProcessedPayroll.GrossPay.ToString("N2")</strong></dd>

                        <dt class="col-sm-4">Tax (15%):</dt>
                        <dd class="col-sm-8 text-danger">-$@Model.ProcessedPayroll.TaxAmount.ToString("N2")</dd>

                        <dt class="col-sm-4">Social Security (6.2%):</dt>
                        <dd class="col-sm-8 text-danger">-$@Model.ProcessedPayroll.SocialSecurityAmount.ToString("N2")</dd>

                        <dt class="col-sm-4">Health Insurance:</dt>
                        <dd class="col-sm-8 text-danger">-$@Model.ProcessedPayroll.HealthInsuranceAmount.ToString("N2")</dd>

                        <dt class="col-sm-4">Total Deductions:</dt>
                        <dd class="col-sm-8 text-danger"><strong>-$@Model.ProcessedPayroll.TotalDeductions.ToString("N2")</strong></dd>

                        <dt class="col-sm-4 border-top pt-2">Net Pay:</dt>
                        <dd class="col-sm-8 border-top pt-2"><h4 class="text-success mb-0">$@Model.ProcessedPayroll.NetPay.ToString("N2")</h4></dd>
                    </dl>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const employeeSelect = document.getElementById('employeeSelect');
            const hoursWorkedField = document.getElementById('hoursWorkedField');

            employeeSelect.addEventListener('change', function() {
                const selectedOption = this.options[this.selectedIndex];
                const employmentType = selectedOption.getAttribute('data-type');

                if (employmentType === 'Hourly') {
                    hoursWorkedField.style.display = 'block';
                } else {
                    hoursWorkedField.style.display = 'none';
                }
            });
        });
    </script>
}
