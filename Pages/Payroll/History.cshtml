@page
@model PayrollApp.Pages.Payroll.HistoryModel
@{
    ViewData["Title"] = "Payment History";
}

<h1>Payment History</h1>
<hr />

<div class="row mb-4">
    <div class="col-md-12">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label for="employeeFilter" class="form-label">Filter by Employee</label>
                <select name="employeeId" id="employeeFilter" class="form-select" onchange="this.form.submit()">
                    <option value="">-- All Employees --</option>
                    @foreach (var employee in Model.Employees)
                    {
                        <option value="@employee.Id" selected="@(Model.FilterEmployeeId == employee.Id)">
                            @employee.EmployeeId - @employee.Name
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label for="startDate" class="form-label">From Date</label>
                <input type="date" name="startDate" id="startDate" class="form-control" 
                       value="@Model.FilterStartDate?.ToString("yyyy-MM-dd")" onchange="this.form.submit()" />
            </div>
            <div class="col-md-3">
                <label for="endDate" class="form-label">To Date</label>
                <input type="date" name="endDate" id="endDate" class="form-control" 
                       value="@Model.FilterEndDate?.ToString("yyyy-MM-dd")" onchange="this.form.submit()" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <a asp-page="History" class="btn btn-secondary w-100">Clear Filters</a>
            </div>
        </form>
    </div>
</div>

@if (Model.PayrollRecords.Count == 0)
{
    <div class="alert alert-info">
        No payroll records found. <a asp-page="/Payroll/Process">Process payroll</a> to create payment records.
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <div class="row">
                <div class="col-md-4">
                    <strong>Total Records:</strong> @Model.PayrollRecords.Count
                </div>
                <div class="col-md-4">
                    <strong>Total Gross Pay:</strong> $@Model.PayrollRecords.Sum(p => p.GrossPay).ToString("N2")
                </div>
                <div class="col-md-4">
                    <strong>Total Net Pay:</strong> $@Model.PayrollRecords.Sum(p => p.NetPay).ToString("N2")
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Employee</th>
                    <th>Pay Period</th>
                    <th>Hours</th>
                    <th>Gross Pay</th>
                    <th>Tax</th>
                    <th>Social Security</th>
                    <th>Health Ins.</th>
                    <th>Total Deductions</th>
                    <th>Net Pay</th>
                    <th>Payment Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model.PayrollRecords)
                {
                    <tr>
                        <td>
                            <strong>@record.Employee?.Name</strong><br />
                            <small class="text-muted">@record.Employee?.EmployeeId</small>
                        </td>
                        <td>
                            @record.PayPeriodStart.ToString("MM/dd/yy")<br />
                            <small class="text-muted">to @record.PayPeriodEnd.ToString("MM/dd/yy")</small>
                        </td>
                        <td>@(record.HoursWorked?.ToString("N1") ?? "N/A")</td>
                        <td><strong>$@record.GrossPay.ToString("N2")</strong></td>
                        <td class="text-danger">$@record.TaxAmount.ToString("N2")</td>
                        <td class="text-danger">$@record.SocialSecurityAmount.ToString("N2")</td>
                        <td class="text-danger">$@record.HealthInsuranceAmount.ToString("N2")</td>
                        <td class="text-danger"><strong>$@record.TotalDeductions.ToString("N2")</strong></td>
                        <td class="text-success"><strong>$@record.NetPay.ToString("N2")</strong></td>
                        <td>@record.PaymentDate.ToString("MM/dd/yyyy")</td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <td colspan="3" class="text-end"><strong>Totals:</strong></td>
                    <td><strong>$@Model.PayrollRecords.Sum(p => p.GrossPay).ToString("N2")</strong></td>
                    <td class="text-danger">$@Model.PayrollRecords.Sum(p => p.TaxAmount).ToString("N2")</td>
                    <td class="text-danger">$@Model.PayrollRecords.Sum(p => p.SocialSecurityAmount).ToString("N2")</td>
                    <td class="text-danger">$@Model.PayrollRecords.Sum(p => p.HealthInsuranceAmount).ToString("N2")</td>
                    <td class="text-danger"><strong>$@Model.PayrollRecords.Sum(p => p.TotalDeductions).ToString("N2")</strong></td>
                    <td class="text-success"><strong>$@Model.PayrollRecords.Sum(p => p.NetPay).ToString("N2")</strong></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
}
